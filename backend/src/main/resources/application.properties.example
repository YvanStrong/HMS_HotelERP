# Copy to application.properties (do not commit secrets) or export as environment variables.

DB_NAME=hms
DB_USER=hms
DB_PASSWORD=your_password_here

# Required for production. If unset, application.properties uses local dev defaults (change them).
JWT_SECRET=replace_with_at_least_32_characters_random_string
# Same value must match Postman setupToken / X-Setup-Token (defaults documented in application.properties).
SETUP_TOKEN=replace_with_strong_random_token_for_first_setup_only

spring.datasource.url=jdbc:postgresql://localhost:5432/${DB_NAME}
spring.datasource.username=${DB_USER}
spring.datasource.password=${DB_PASSWORD}

hms.jwt.secret=${JWT_SECRET}
hms.setup.token=${SETUP_TOKEN}

# HMS_CHECK_OUT_LAST_NIGHT_INCLUSIVE=true — treat API check-out as last night of stay (room free from next calendar day).

# Optional: defaults to 8080 in application.properties when unset
# SERVER_PORT=8082
